  "keyFeatures": [
    "Multi-session inbox with workflow statuses",
    "MCP server and REST API integration",
    "Three-level permission system (Explore, Ask to Edit, Auto)",
    "Multiple LLM provider support (Anthropic, Google AI, OpenAI, GitHub Copilot)",
    "Custom skills and automations",
    "Dynamic status workflows",
    "Encrypted credential storage",
    "Theme customization",
    "File attachments and drag-drop support",
    "Background task execution"
  ],
  "publicApiSurface": [
    "craftagents:// deep linking protocol",
    "Session management API (SessionManager)",
    "MCP client pool (McpClientPool)",
    "CraftAgent class",
    "Permission modes: safe, ask, allow-all",
    "Source types: mcp, api, local, gmail",
    "OAuth integrations: Google, Slack, Microsoft",
    "Automation events: LabelAdd, SessionStart, SchedulerTick",
    "Theme configuration API",
    "Credential manager (AES-256-GCM encrypted)",
    "Session-scoped tools: source_test, config_validate",
    "Status CRUD operations"
  ]
